{
  "name": "aurora",
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/frontend",
    "services/media"
  ],
  "scripts": {
    "lint": "bun run lint:ts && bun run lint:py",
    "lint:ts": "eslint \"apps/**/*.ts\" --max-warnings=0",
    "lint:py": "ruff check services/media",
    "typecheck": "bun run --cwd apps/backend typecheck && bun run --cwd apps/frontend typecheck",
    "test": "bun --cwd apps/backend test"
  },
  "dependencies": {
    "@quinteroac/agents-coding-toolkit": "^0.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.14",
    "bun-types": "^1.3.4",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
