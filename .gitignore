# -----------------------------------------------------------------------------
# Aurora — .gitignore (Bun · React · Python · comfy-diffusion)
# -----------------------------------------------------------------------------

# ----- Environment & secrets -----
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# ----- OS & IDE -----
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ----- Bun / Node (backend, frontend, monorepo) -----
node_modules/
bun.lockb
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# ----- Build & output (ElysiaJS, React, Vite) -----
dist/
build/
out/
.next/
.nuxt/
.output/
*.tsbuildinfo
.turbo/

# ----- Python (media service, comfy-diffusion) -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
env/
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
*.egg
*.egg-info/
.eggs/
*.manifest
*.spec
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
*.whl

# ----- comfy-diffusion / ML models & outputs -----
checkpoints/
models/
output/
outputs/
*.ckpt
*.safetensors
*.bin
*.pt
*.pth
comfy-diffusion/output/
media_output/
generated/

# ----- Persistence (local dev) -----
*.db
*.sqlite
*.sqlite3
data/
redis/dump.rdb
postgres_data/
pgdata/
s3-local/
storage/

# ----- Logs & temp -----
logs/
*.log
tmp/
temp/
.cache/

# ----- Testing & coverage -----
coverage/
.nyc_output/
junit.xml
test-results/
playwright-report/
.playwright/

# ----- Agent / NVST (optional: uncomment if generated content should not be committed) -----
# .agents/
# docs/nvst-flow/

# ----- Editor / Cursor -----
.idea/
*.iml
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# ----- Misc -----
*.local
