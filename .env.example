BACKEND_PORT=3000 # Port used by the Elysia backend service
FRONTEND_PORT=5173 # Port used by the Vite frontend development server
MEDIA_PORT=8000 # Port used by the FastAPI media service
OPENAI_API_KEY=your_openai_api_key_here # API key for the Narrator LLM (OpenAI, Open Router, or compatible gateway)
OPENAI_BASE_URL=https://api.openai.com/v1 # Base URL for the Narrator LLM (e.g. https://openrouter.ai/api/v1 for Open Router). Use the base only; Mastra appends /chat/completions.
ANTHROPIC_API_KEY=your_anthropic_api_key_here # Reserved for future use (e.g. Anthropic provider)

# LLM configuration for Narrator agent (apps/backend)
NARRATOR_MODEL=openai/gpt-4o-mini # Model id for the Narrator. With Open Router use openrouter/provider/model (e.g. openrouter/z-ai/glm-4.5-air:free)


# Frontend → Backend connection (apps/frontend)
VITE_BACKEND_URL=http://localhost:${BACKEND_PORT} # Base HTTP URL for the backend (used for REST)
VITE_BACKEND_WS_URL=ws://localhost:${BACKEND_PORT}/ws # Optional explicit WebSocket URL for the backend (/ws). If not set, it will be derived from VITE_BACKEND_URL.

# Media service — comfy-diffusion pipeline (services/media)
MODELS_DIR=models # Absolute or relative path to the directory containing model checkpoints
CHECKPOINT=illustrious_xl.safetensors # Filename of the SDXL checkpoint to load (must exist inside MODELS_DIR)
LORA= # Optional: path to a LoRA file (.safetensors) to apply during image generation
